generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["accounting", "auth", "channel", "payout", "product", "sales", "warehouse"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model account_categories {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(50)
  report_type String     @db.VarChar(50)
  accounts    accounts[]

  @@schema("accounting")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model accounts {
  id                                                                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id                                                            Int?
  parent_id                                                              String?                @db.Uuid
  code                                                                   String                 @unique @db.VarChar(50)
  name                                                                   String                 @db.VarChar(255)
  normal_balance                                                         String                 @db.VarChar(20)
  is_active                                                              Boolean                @default(true)
  created_at                                                             DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                                                             DateTime?              @db.Timestamptz(6)
  account_categories                                                     account_categories?    @relation(fields: [category_id], references: [id], onDelete: Restrict, map: "fk_accounts_category_id")
  accounts                                                               accounts?              @relation("accountsToaccounts", fields: [parent_id], references: [id], onDelete: Restrict, map: "fk_accounts_parent_id")
  other_accounts                                                         accounts[]             @relation("accountsToaccounts")
  journal_lines                                                          journal_lines[]
  m_channel_m_channel_piutang_account                                    m_channel[]           @relation("m_channel_piutang_account")
  m_channel_m_channel_revenue_account                                    m_channel[]           @relation("m_channel_revenue_account")
  m_channel_m_channel_saldo_account                                      m_channel[]           @relation("m_channel_saldo_account")
  operational_expenses_operational_expenses_expense_account_idToaccounts operational_expenses[] @relation("operational_expenses_expense_account_idToaccounts")
  operational_expenses_operational_expenses_payment_account_idToaccounts operational_expenses[] @relation("operational_expenses_payment_account_idToaccounts")
  payout_transfers_payout_transfers_bank_account_idToaccounts            payout_transfers[]    @relation("payout_transfers_bank_account_id")

  @@index([category_id], map: "idx_accounting_accounts_category_id")
  @@index([parent_id], map: "idx_accounting_accounts_parent_id")
  @@schema("accounting")
}

model journal_entries {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transaction_date DateTime        @db.Date
  reference_type   String          @db.VarChar(50)
  reference_id     String?         @db.Uuid
  description      String
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?       @db.Timestamptz(6)
  journal_lines    journal_lines[]

  @@index([reference_type], map: "idx_accounting_journal_entries_reference_type")
  @@schema("accounting")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model journal_lines {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  journal_entry_id String          @db.Uuid
  account_id       String          @db.Uuid
  debit            Decimal         @default(0.00) @db.Decimal(18, 2)
  credit           Decimal         @default(0.00) @db.Decimal(18, 2)
  memo             String?         @db.VarChar(255)
  accounts         accounts        @relation(fields: [account_id], references: [id], map: "fk_journal_lines_account_id")
  journal_entries  journal_entries @relation(fields: [journal_entry_id], references: [id], onDelete: Cascade, map: "fk_journal_lines_journal_entry_id")

  @@index([account_id], map: "idx_accounting_journal_lines_account_id")
  @@index([journal_entry_id], map: "idx_accounting_journal_lines_journal_entry_id")
  @@schema("accounting")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model operational_expenses {
  id                                                         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expense_date                                               DateTime          @db.Date
  expense_account_id                                         String            @db.Uuid
  payment_account_id                                         String?           @db.Uuid
  is_product_barter                                          Boolean           @default(false)
  qty                                                        Int               @default(0)
  amount                                                     Decimal           @db.Decimal(18, 2)
  description                                                String
  receipt_url                                                String?           @db.VarChar(255)
  created_at                                                 DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                                                 DateTime?         @db.Timestamptz(6)
  inv_code                                                   String?           @db.VarChar(100)
  accounts_operational_expenses_expense_account_idToaccounts accounts          @relation("operational_expenses_expense_account_idToaccounts", fields: [expense_account_id], references: [id], map: "fk_operational_expenses_expense_account_id")
  master_inventory                                           master_inventory? @relation(fields: [inv_code], references: [inv_code], onDelete: Restrict, map: "fk_operational_expenses_inv_code")
  accounts_operational_expenses_payment_account_idToaccounts accounts?         @relation("operational_expenses_payment_account_idToaccounts", fields: [payment_account_id], references: [id], onDelete: Restrict, map: "fk_operational_expenses_payment_account_id")

  @@index([expense_account_id], map: "idx_accounting_operational_expenses_expense_account_id")
  @@index([inv_code], map: "idx_accounting_operational_expenses_inv_code")
  @@index([payment_account_id], map: "idx_accounting_operational_expenses_payment_account_id")
  @@schema("accounting")
}

model roles {
  id          Int      @id @default(autoincrement())
  role_name   String   @unique @db.VarChar(100)
  permissions Json     @default("{}")
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users[]

  @@schema("auth")
}

model users {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       Int?
  username      String    @unique @db.VarChar(100)
  full_name     String?   @db.VarChar(150)
  password_hash String
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @db.Timestamptz(6)
  is_active     Boolean   @default(true)
  roles         roles?    @relation(fields: [role_id], references: [id], onDelete: Restrict)

  @@index([role_id], map: "idx_auth_users_role_id")
  @@schema("auth")
}

model m_channel {
  channel_id         Int                 @id @default(autoincrement())
  category_id        Int?
  piutang_account_id String?             @db.Uuid
  revenue_account_id String?             @db.Uuid
  saldo_account_id   String?             @db.Uuid
  channel_name       String              @db.VarChar(100)
  slug               String?             @unique @db.VarChar(100)
  is_marketplace     Boolean             @default(false)
  created_at         DateTime            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?           @db.Timestamptz(6)
  m_channel_category m_channel_category? @relation(fields: [category_id], references: [category_id], onDelete: Restrict, map: "fk_channel_channel_category_id")
  piutang_account    accounts?           @relation("m_channel_piutang_account", fields: [piutang_account_id], references: [id], onDelete: Restrict, map: "fk_m_channel_piutang_account")
  revenue_account    accounts?           @relation("m_channel_revenue_account", fields: [revenue_account_id], references: [id], onDelete: Restrict, map: "fk_m_channel_revenue_account")
  saldo_account      accounts?           @relation("m_channel_saldo_account", fields: [saldo_account_id], references: [id], onDelete: Restrict, map: "fk_m_channel_saldo_account")
  t_adjustments      t_adjustments[]
  t_order            t_order[]

  @@index([category_id], map: "idx_channel_m_channel_category_id")
  @@index([piutang_account_id], map: "idx_m_channel_piutang_account_id")
  @@index([revenue_account_id], map: "idx_m_channel_revenue_account_id")
  @@index([saldo_account_id], map: "idx_m_channel_saldo_account_id")
  @@schema("channel")
}

model m_channel_category {
  category_id     Int              @id @default(autoincrement())
  group_id        Int?
  category_name   String           @db.VarChar(50)
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  m_channel       m_channel[]
  m_channel_group m_channel_group? @relation(fields: [group_id], references: [group_id], onDelete: Restrict, map: "fk_channel_category_group_id")

  @@schema("channel")
}

model m_channel_group {
  group_id           Int                  @id @default(autoincrement())
  group_name         String               @unique @db.VarChar(50)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  m_channel_category m_channel_category[]

  @@schema("channel")
}

model t_adjustments {
  adjustment_id   Int        @id @default(autoincrement())
  ref             String?    @db.VarChar(100)
  payout_date     DateTime   @db.Date
  adjustment_date DateTime?  @db.Date
  channel_id      Int?
  adjustment_type String?    @db.VarChar(100)
  reason          String?
  amount          Decimal    @db.Decimal(18, 2)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  m_channel       m_channel? @relation(fields: [channel_id], references: [channel_id], onDelete: Restrict, map: "fk_t_adjustments_channel_id")
  t_order         t_order?   @relation(fields: [ref], references: [ref_no], onDelete: Restrict, map: "fk_t_adjustments_ref")

  @@index([channel_id], map: "idx_payout_t_adjustments_channel_id")
  @@index([ref], map: "idx_payout_t_adjustments_ref")
  @@schema("payout")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model t_payout {
  payout_id         Int      @id @default(autoincrement())
  ref               String?  @unique @db.VarChar(100)
  payout_date       DateTime @db.Date
  qty_produk        Int      @default(0)
  hpp               Decimal  @default(0.00) @db.Decimal(18, 2)
  total_price       Decimal  @default(0.00) @db.Decimal(18, 2)
  seller_discount   Decimal  @default(0.00) @db.Decimal(18, 2)
  fee_admin         Decimal  @default(0.00) @db.Decimal(18, 2)
  fee_service       Decimal  @default(0.00) @db.Decimal(18, 2)
  fee_order_process Decimal  @default(0.00) @db.Decimal(18, 2)
  fee_program       Decimal  @default(0.00) @db.Decimal(18, 2)
  fee_transaction   Decimal  @default(0.00) @db.Decimal(18, 2)
  fee_affiliate     Decimal  @default(0.00) @db.Decimal(18, 2)
  shipping_cost     Decimal  @default(0.00) @db.Decimal(18, 2)
  omset             Decimal  @default(0.00) @db.Decimal(18, 2)
  payout_status     String?  @db.VarChar(20)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  t_order           t_order? @relation(fields: [ref], references: [ref_no], onDelete: Restrict, map: "fk_t_payout_ref")
  payout_transfers  payout_transfers[]

  @@schema("payout")
}

model payout_transfers {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payout_id       Int
  transfer_date   DateTime  @db.Date
  amount          Decimal   @db.Decimal(18, 2)
  bank_account_id String    @db.Uuid
  notes           String?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @db.Timestamptz(6)
  accounts        accounts  @relation("payout_transfers_bank_account_id", fields: [bank_account_id], references: [id], onDelete: Restrict, map: "fk_payout_transfers_bank_account_id")
  t_payout        t_payout  @relation(fields: [payout_id], references: [payout_id], onDelete: Cascade, map: "fk_payout_transfers_payout_id")

  @@index([bank_account_id], map: "idx_payout_transfers_bank_account_id")
  @@index([payout_id], map: "idx_payout_transfers_payout_id")
  @@schema("payout")
}

